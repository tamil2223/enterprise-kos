APP_ENV=dev

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated). Used by the Next.js playground UI in local dev.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex to allow additional localhost ports without listing each one.
CORS_ALLOW_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1):(3000|3001|3002|3003)

# Context shaping
CONTEXT_MAX_CHARS=8000
TOP_K_DEFAULT=5
RETRIEVAL_MAX_CANDIDATES=8000

# Local corpus directory (txt/md files)
DATA_DIR=data/corpus
